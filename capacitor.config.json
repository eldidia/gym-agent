{
  "appId": "com.gymagent.app",
  "appName": "GymAgent",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "buildOptions": {
      "keystorePath": null,
      "keystorePassword": null,
      "keystoreAlias": null,
      "keystoreAliasPassword": null,
      "releaseType": "APK"
    }
  },
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a12",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "SplashScreen": {
      "launchShowDuration": 0
    }
  }
}
